    </Reference>
    <Reference Include="Newtonsoft.Json">
      <HintPath>$(MelonLoaderDir)\net6\Newtonsoft.Json.dll</HintPath>
    </Reference>
    <Reference Include="System.Configuration.ConfigurationManager">
      <HintPath>$(MelonLoaderDir)\net6\System.Configuration.ConfigurationManager.dll</HintPath>
    </Reference>
    <Reference Include="System.Diagnostics.DiagnosticSource">
      <HintPath>$(MelonLoaderDir)\net6\System.Diagnostics.DiagnosticSource.dll</HintPath>
