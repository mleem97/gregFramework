    </Reference>
    <Reference Include="Mono.Cecil.Rocks">
      <HintPath>$(MelonLoaderDir)\net6\Mono.Cecil.Rocks.dll</HintPath>
    </Reference>
    <Reference Include="MonoMod">
      <HintPath>$(MelonLoaderDir)\net6\MonoMod.dll</HintPath>
    </Reference>
    <Reference Include="MonoMod.Backports">
      <HintPath>$(MelonLoaderDir)\net6\MonoMod.Backports.dll</HintPath>
