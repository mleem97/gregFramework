<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkshopUploader.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="DataCenterWS">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Style="{StaticResource Headline}" Text="Workshop projects" />
            <Label x:Name="WorkspacePathLabel" Style="{StaticResource SubHeadline}" />
        </VerticalStackLayout>

        <RefreshView Grid.Row="1" Refreshing="OnRefreshing" x:Name="RefreshView">
            <CollectionView
                x:Name="ProjectList"
                SelectionMode="Single"
                SelectionChanged="OnProjectSelected">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" StrokeThickness="1">
                            <VerticalStackLayout Spacing="6">
                                <Label FontAttributes="Bold" FontSize="16" Text="{Binding Name}" />
                                <Label FontSize="11" Opacity="0.75" LineBreakMode="TailTruncation" MaxLines="2" Text="{Binding RootPath}" />
                                <Label FontSize="12" Text="{Binding StatusText}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <Border Grid.Row="2" Padding="8" StrokeThickness="1">
            <VerticalStackLayout Spacing="4">
                <Label FontAttributes="Bold" Text="Log" />
                <ScrollView x:Name="LogScroll" HeightRequest="140">
                    <Label x:Name="LogLabel" FontFamily="Consolas" FontSize="11" LineBreakMode="WordWrap" />
                </ScrollView>
            </VerticalStackLayout>
        </Border>
    </Grid>

</ContentPage>
