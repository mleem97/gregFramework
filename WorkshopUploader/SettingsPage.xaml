<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkshopUploader.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:WorkshopUploader.Localization"
    Title="{l:Translate Key=Tab_Settings}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <VerticalStackLayout Spacing="6">
                <Label Style="{StaticResource Headline}" Text="{l:Translate Key=Settings_Headline}" />
                <Label Style="{StaticResource SubHeadline}" Text="{l:Translate Key=Settings_Subtitle}" />
            </VerticalStackLayout>

            <!--  Mod Store toggle  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="#001715">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Settings_ModStore}" />
                    <Label FontSize="12" TextColor="#7FBFB8" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Settings_ModStoreDesc}" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" FontSize="13" TextColor="#C0FCF6" VerticalOptions="Center"
                            Text="{l:Translate Key=Settings_EnableModStore}" />
                        <Switch x:Name="ModStoreSwitch" Grid.Column="1"
                            OnColor="#61F4D8" ThumbColor="#C0FCF6"
                            Toggled="OnModStoreToggled" />
                    </Grid>
                    <HorizontalStackLayout Spacing="8">
                        <Label x:Name="ModStoreHint" FontSize="11" TextColor="#5A9E96" VerticalOptions="Center"
                            Text="{l:Translate Key=Settings_RestartRequired}" />
                        <Button x:Name="ModStoreRestartBtn" Text="{l:Translate Key=Settings_RestartNow}"
                            Clicked="OnRestartApp" Style="{StaticResource TertiaryButton}" IsVisible="False" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  Workspace path  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="#001715">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Settings_Workspace}" />
                    <Label FontSize="12" TextColor="#7FBFB8" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Settings_WorkspaceDesc}" />
                    <Label x:Name="CurrentPathLabel" FontSize="11" TextColor="#5A9E96" LineBreakMode="WordWrap" />
                    <Entry x:Name="CustomPathEntry" Placeholder="{l:Translate Key=Settings_CustomPath}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="{l:Translate Key=Settings_Browse}" Clicked="OnBrowseFolder" Style="{StaticResource SecondaryButton}" />
                        <Button Text="{l:Translate Key=Settings_Apply}" Clicked="OnApplyPath" />
                        <Button Text="{l:Translate Key=Settings_ResetDefault}" Clicked="OnResetPath" Style="{StaticResource TertiaryButton}" />
                    </HorizontalStackLayout>
                    <Label x:Name="PathHint" FontSize="11" TextColor="#5A9E96" />
                </VerticalStackLayout>
            </Border>

            <!--  Language  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="#001715">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Settings_Language}" />
                    <Label FontSize="12" TextColor="#7FBFB8" LineBreakMode="WordWrap"
                        Text="{l:Translate Key=Settings_LanguageDesc}" />
                    <Picker x:Name="LanguagePicker" SelectedIndexChanged="OnLanguageChanged" />
                    <HorizontalStackLayout Spacing="8">
                        <Label x:Name="LanguageHint" FontSize="11" TextColor="#5A9E96" VerticalOptions="Center"
                            Text="{l:Translate Key=Settings_LanguageRestart}" />
                        <Button x:Name="LanguageRestartBtn" Text="{l:Translate Key=Settings_RestartNow}"
                            Clicked="OnRestartApp" Style="{StaticResource TertiaryButton}" IsVisible="False" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!--  Community links  -->
            <Border Padding="20" StrokeThickness="0" BackgroundColor="#001715">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=Settings_Community}" />
                    <Button Text="{l:Translate Key=Settings_Discord}" Clicked="OnOpenDiscord" Style="{StaticResource SecondaryButton}" HorizontalOptions="Start" />
                    <Button Text="{l:Translate Key=Settings_ModdingChannel}" Clicked="OnOpenModdingChannel" Style="{StaticResource SecondaryButton}" HorizontalOptions="Start" />
                    <Button Text="{l:Translate Key=Settings_Website}" Clicked="OnOpenWebsite" Style="{StaticResource SecondaryButton}" HorizontalOptions="Start" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
