<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkshopUploader.NewProjectPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:l="clr-namespace:WorkshopUploader.Localization"
    Title="{l:Translate Key=Tab_New}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">
            <Label Style="{StaticResource Headline}" Text="{l:Translate Key=NewProject_Headline}" />
            <Label Style="{StaticResource SubHeadline}" Text="{l:Translate Key=NewProject_Subtitle}" />

            <Border Padding="20" StrokeThickness="0" BackgroundColor="#001715">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Style="{StaticResource SectionTitle}" Text="{l:Translate Key=NewProject_Template}" />
                    <Picker x:Name="TemplateKindPicker" Title="{l:Translate Key=NewProject_TemplateType}" />
                    <Entry x:Name="NewProjectNameEntry" Placeholder="{l:Translate Key=NewProject_FolderPlaceholder}" />
                    <Button Clicked="OnCreateTemplate" Text="{l:Translate Key=NewProject_Create}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
